APP_NAME="Alihmedia BPN"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ==========================================
# DATABASE - Ganti sesuai server kantor
# ==========================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=admin_alihmedia
DB_USERNAME=admin_alihmedia
DB_PASSWORD=your_password_here

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ==========================================
# SANCTUM - Token auth
# ==========================================
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:5173,127.0.0.1,127.0.0.1:8000

# ==========================================
# CORS - Frontend URL
# ==========================================
FRONTEND_URL=http://localhost:5173

# ==========================================
# FILE UPLOAD
# ==========================================
UPLOAD_MAX_SIZE=5120
