<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Handle Authorization Header - forward to PHP
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle CORS preflight cleanly without redirect body
    RewriteCond %{REQUEST_METHOD} =OPTIONS
    RewriteRule ^ - [R=204,L]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# ============================================
# CORS Headers - SATU-SATUNYA sumber CORS
# Apache menangani semua header CORS
# Laravel middleware CORS sudah dinonaktifkan
# ============================================
<IfModule mod_headers.c>
    # Match allowed origins dynamically
    SetEnvIf Origin "^https?://(dev-alihmedia\.kantahkabbogor\.id|alihmedia\.kantahkabbogor\.id|alih-media\.lovable\.app|id-preview--fd14bb51-b1c6-4db0-9718-5bf0922a471c\.lovable\.app|fd14bb51-b1c6-4db0-9718-5bf0922a471c\.lovableproject\.com|localhost(:3000|:5173)?)$" CORS_ORIGIN=$0

    Header always merge Vary Origin
    Header always set Access-Control-Allow-Origin "%{CORS_ORIGIN}e" env=CORS_ORIGIN
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS" env=CORS_ORIGIN
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, X-Access-Token, Accept, Origin" env=CORS_ORIGIN
    Header always set Access-Control-Allow-Credentials "true" env=CORS_ORIGIN
    Header always set Access-Control-Max-Age "86400" env=CORS_ORIGIN
</IfModule>

# Ensure PHP receives Authorization header via CGI/FastCGI
<IfModule mod_setenvif.c>
    SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>
